# =============================================
# Supabase 環境變數
# =============================================
# 1. 複製這個檔案，重新命名為 .env.local
# 2. 到 Supabase 後台 → Project Settings → API
# 3. 填入你的 Project URL 和 anon public key

NEXT_PUBLIC_SUPABASE_URL=https://你的project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_public_key

# =============================================
# 注意事項
# =============================================
# - .env.local 已加入 .gitignore，不會被推上 GitHub
# - 部署到 Vercel 時，要在 Vercel 後台手動新增這兩個變數
# - 變數名稱前綴 NEXT_PUBLIC_ 讓 Next.js 將這些值暴露給瀏覽器端
# - 永遠不要把真實的 Key 寫在程式碼或 .env.example 裡
